<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BoulderGame.App"
             RequestedThemeVariant="Light">
    
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://BoulderGame/Resources/Styles.axaml"/>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://BoulderGame/Resources/Languages/English-US.axaml"/>
                <ResourceInclude Source="avares://BoulderGame/Resources/Languages/Ukrainian-UA.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
    
</Application>