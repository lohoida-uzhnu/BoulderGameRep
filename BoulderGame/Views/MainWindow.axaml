<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BoulderGame.MainWindow"
        Title="MainMenu"
        Width="800" Height="600"
        MinWidth="800" MinHeight="600"

        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="*, 2*, Auto">
        
        <StackPanel Grid.Row="0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <TextBlock Text="DODGE BOULDER" 
                       Classes="Header"/>
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Spacing="15"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top">
            <Button 
                    Content="{DynamicResource StartGame}" 
                    Click="StartGameBut_Click" 
                    Classes="MenuBtn"/>
            <Button 
                    Content="{DynamicResource Stat}" 
                    Click="StatButton_Click" 
                    Classes="MenuBtn"/>
            <Button 
                    Content="{DynamicResource Sett}" 
                    Click="SettingBut_Click" 
                    Classes="MenuBtn"/>
            <Button 
                    Content="{DynamicResource Exit}" 
                    Background="#EF4444"
                    Click="ExitButton_Click" 
                    Classes="MenuBtn"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Margin="10"
                    HorizontalAlignment="Left">
            <TextBlock Text="Version: Release 1.0" 
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </StackPanel>

        <ContentControl Name="MainContent" IsHitTestVisible="False"/>

        <Border Name="DifficultyOverlay"
                Grid.RowSpan="3"
                Background="#AA000000"
                IsVisible="False"
                ZIndex="50">
            <Border Background="{DynamicResource SystemRegionBrush}"
                    Padding="32"
                    CornerRadius="12"
                    Width="440"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BoxShadow="0 10 30 0 #50000000">
                <StackPanel Spacing="14">
                    <TextBlock Text="{DynamicResource ChooseD}"
                               FontSize="28"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Name="SecretLevelHint"
                               Text="{DynamicResource SecretLUA}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"/>

                    <Button Content="{DynamicResource Easy}"
                            Tag="Easy"
                            Click="DifficultyButton_Click"
                            Classes="MenuBtn"
                            HorizontalAlignment="Center"/>
                    <Button Content="{DynamicResource Normal}"
                            Tag="Normal"
                            Click="DifficultyButton_Click"
                            Classes="MenuBtn"
                            HorizontalAlignment="Center"/>
                    <Button Content="{DynamicResource Hard}"      
                            Tag="Hard"
                            Click="DifficultyButton_Click"
                            Classes="MenuBtn"
                            HorizontalAlignment="Center"/>
                    <Button Name="SecretLevelButton"
                            Content="{DynamicResource Secret}"
                            Tag="Secret"
                            Click="DifficultyButton_Click"
                            Classes="MenuBtn"
                            HorizontalAlignment="Center"/>
                    <Button Content="{DynamicResource BackTM}"
                            Click="CloseDifficultyMenu_Click"
                            Classes="MenuBtn"
                            Background="#475569"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
